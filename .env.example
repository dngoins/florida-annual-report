# ============================================================
# Florida Annual Report Automation Platform
# Environment Variables Template
#
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.
# All secrets should be retrieved from Azure Key Vault in prod.
# ============================================================

# ── Node Environment ─────────────────────────────────────────
NODE_ENV=development                  # development | staging | production

# ── API Gateway ──────────────────────────────────────────────
PORT=3001
API_VERSION=v1
CORS_ORIGIN=http://localhost:3000     # Frontend origin (comma-separated for multiple)
LOG_LEVEL=info                        # debug | info | warn | error
RATE_LIMIT_WINDOW_MS=900000           # 15 minutes
RATE_LIMIT_MAX=100                    # requests per window

# ── Frontend (Next.js) ───────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=                      # Generate: openssl rand -base64 32

# ── Azure SQL Database ───────────────────────────────────────
DB_HOST=                              # <name>.database.windows.net
DB_PORT=1433
DB_NAME=florida_annual_report
DB_USER=flaradmin
DB_PASSWORD=                          # From Azure Key Vault: sql-admin-password
DB_SSL=true

# ── Azure BLOB Storage ───────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=      # From Azure Key Vault: storage-connection-string
AZURE_STORAGE_CONTAINER=documents
AZURE_STORAGE_RECEIPTS_CONTAINER=receipts

# ── Azure CosmosDB ───────────────────────────────────────────
COSMOS_CONNECTION_STRING=             # From Azure Key Vault: cosmos-connection-string
COSMOS_DATABASE=florida_annual_report
COSMOS_CONTAINER=processed_documents

# ── Azure Key Vault ──────────────────────────────────────────
AZURE_KEYVAULT_URI=                   # https://<vault-name>.vault.azure.net/
# Leave blank in dev; Container Apps use managed identity in staging/prod

# ── Azure Container Registry ─────────────────────────────────
ACR_NAME=                             # e.g. flardev (no .azurecr.io suffix)
ACR_LOGIN_SERVER=                     # e.g. flardev.azurecr.io

# ── OAuth2 / Authentication ──────────────────────────────────
# At least one provider required
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=                  # Use 'common' for multi-tenant

# ── MFA (TOTP) ───────────────────────────────────────────────
MFA_ISSUER=FloridaAnnualReport
MFA_ENCRYPTION_KEY=                   # Generate: openssl rand -hex 32

# ── AWS Textract (OCR) ───────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── Anthropic (LLM fallback + Agent) ─────────────────────────
ANTHROPIC_API_KEY=                    # Required for extraction LLM fallback
ANTHROPIC_MODEL=claude-opus-4-5

# ── Extraction Service (Python/FastAPI) ──────────────────────
EXTRACTION_SERVICE_URL=http://localhost:8000
EXTRACTION_SERVICE_PORT=8000
CONFIDENCE_THRESHOLD=0.75             # Fields below this score require human review

# ── Playwright / Sunbiz Automation ───────────────────────────
SUNBIZ_URL=https://dos.myflorida.com/sunbiz/
PLAYWRIGHT_HEADLESS=true              # Set false for local debugging
PLAYWRIGHT_TIMEOUT_MS=30000
SUNBIZ_SELECTORS_PATH=integrations/sunbiz/selectors.json

# ── Filing Deadline ───────────────────────────────────────────
FILING_DEADLINE_MONTH=5               # May
FILING_DEADLINE_DAY=1
DEADLINE_WARNING_DAYS=30              # Warn users this many days before deadline

# ── Audit Logging ─────────────────────────────────────────────
AUDIT_LOG_TABLE=audit_logs            # AzureSQL table name (append-only)

# ── Local Development Only ────────────────────────────────────
# (docker-compose sets these automatically)
SQL_SERVER_SA_PASSWORD=               # Local SQL Server container SA password
AZURITE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OGLjX+Y5oBM=;BlobEndpoint=http://127.0.0.1:10000/devstoreaccount1;
