# Florida Annual Report API Gateway - Environment Variables
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3000
NODE_ENV=development

# CORS Configuration
CORS_ORIGIN=*

# Logging
LOG_LEVEL=info

# API Version
API_VERSION=v1

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Database (Azure SQL) - Fill in your values
# DB_HOST=your-server.database.windows.net
# DB_PORT=1433
# DB_NAME=florida_annual_report
# DB_USER=your-username
# DB_PASSWORD=<from Azure Key Vault>

# Azure Blob Storage - Fill in your values
# AZURE_STORAGE_CONNECTION_STRING=<from Azure Key Vault>
# AZURE_STORAGE_CONTAINER=documents

# AWS Textract - Fill in your values
# AWS_ACCESS_KEY_ID=<from Azure Key Vault>
# AWS_SECRET_ACCESS_KEY=<from Azure Key Vault>
# AWS_REGION=us-east-1
